{
  "name": "@ufo/timeline-track",
  "version": "2.3.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "description": "时间线轨道组件 — Custom Elements v1 + Pointer Events",
  "main": "dist/TimelineTrack.js",
  "exports": {
    ".": "./dist/TimelineTrack.js",
    "./vue": {
      "import": "./vue/index.js",
      "default": "./vue/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "build:lib:dev": "cross-env TIMELINE_FORMAT=dev vite build --mode lib",
    "build:lib:watch": "vite build --mode lib --watch",
    "build:all": "vite build && vite build --mode lib && cross-env TIMELINE_FORMAT=dev vite build --mode lib",
    "preview": "vite preview"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "vue": "^3.5.0",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "cross-env": "^10.1.0",
    "vite": "^6.3.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
