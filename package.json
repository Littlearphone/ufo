{
  "name": "ufo",
  "version": "1.0.0",
  "private": true,
  "description": "UFO 自定义元素组件库 — Monorepo",
  "scripts": {
    "build": "pnpm -r run build",
    "build:all": "pnpm -r run build:all",
    "build:lib": "pnpm -r run build:lib",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
